# NextAuth
NEXTAUTH_SECRET=your-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Optional: Credentials demo accepts any email with password "password"
# For production use a database and verify credentials.

# Google OAuth (for "Sign in with Google" / Gmail)
# 1. https://console.cloud.google.com/apis/credentials → Create OAuth 2.0 Client ID (Web application)
# 2. Authorized JavaScript origins (add both if you use local + production):
#    http://localhost:3000
#    https://shrishticloud.kitchen
# 3. Authorized redirect URIs (must match NEXTAUTH_URL exactly):
#    http://localhost:3000/api/auth/callback/google
#    https://shrishticloud.kitchen/api/auth/callback/google
# 4. Copy Client ID + Secret below. On Vercel: add these env vars + NEXTAUTH_URL=https://shrishticloud.kitchen → Redeploy
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay (payment)
# Use Key ID in client (NEXT_PUBLIC) and Key ID + Secret on server
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY=rzp_test_xxxx

# Optional: Admin access (email containing "admin" or this exact email)
ADMIN_EMAIL=admin@example.com

# Optional: Database (for production; replace in-memory orders)
# DATABASE_URL=postgresql://...
